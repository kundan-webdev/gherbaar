PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/gharbaar
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Optional: set these in production to store uploaded photos/documents on Cloudinary
# instead of the server's local disk. Leave unset for local dev (falls back to /uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
